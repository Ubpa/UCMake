#!/usr/bin/env bash
# pre-commit hook for @PROJECT_NAME@
# Generated by UCMake at cmake configure time. Do NOT edit manually.
# To activate: register this script with your hook framework, e.g.:
#   python .more-hooks/more-hooks.py register . \
#     --hook pre-commit --id @PROJECT_NAME_LOWER@-ci \
#     --script .ucmake/hooks/pre-commit --priority 80 --symlink

BUILD_DIR="@CMAKE_BINARY_DIR@"

if [ ! -d "$BUILD_DIR" ]; then
    echo "[@PROJECT_NAME@/pre-commit] build/ not found, skipping"
    exit 0
fi

echo "[@PROJECT_NAME@/pre-commit] Building and running tests..."
if ! cmake --build "$BUILD_DIR" --config @UCMAKE_DEFAULT_CONFIG@ --target @PROJECT_NAME@_Check 2>&1; then
    echo "[@PROJECT_NAME@/pre-commit] Build or tests failed. Commit aborted."
    exit 1
fi

echo "[@PROJECT_NAME@/pre-commit] Build and tests passed."
