#!/usr/bin/env bash
# codocs commit-msg hook (auto-installed by codocs init)
#
# Handles flags set by pre-commit:
#   codocs_needs_doc_check        — code changed without doc change (Phase 2)
#   codocs_needs_parent_sync      — .codocs/ MD changed without parent MD sync (Phase 3)
#   codocs_needs_dep_check        — dependency docs not updated (Phase 4)
#   codocs_needs_stale_dir_check  — directory doc content hash is stale (STALE_DIR)
#
# Skip syntax in commit message (Markdown section):
#
#   ## codocs-skip
#   - .codocs/src.md: 理由              ← path-specific skip
#   - .codocs/include.md: 理由          ← path-specific skip
#   - [all]: 理由                        ← global skip (must use explicit [all] keyword)
#
# Only "[all]" triggers a global skip. Entries not starting with ".codocs/"
# and not matching "[all]" are IGNORED (prevents accidental global skip from typos).

COMMIT_MSG_FILE="$1"
PENDING_FLAG="${TMPDIR:-/tmp}/codocs_needs_doc_check"
PENDING_FILES="${TMPDIR:-/tmp}/codocs_pending_files"
PARENT_SYNC_FLAG="${TMPDIR:-/tmp}/codocs_needs_parent_sync"
MISSING_PARENTS="${TMPDIR:-/tmp}/codocs_missing_parents"
DEPS_FLAG="${TMPDIR:-/tmp}/codocs_needs_dep_check"
DEPS_FILE="${TMPDIR:-/tmp}/codocs_missing_deps"
STALE_DIR_FLAG="${TMPDIR:-/tmp}/codocs_needs_stale_dir_check"
STALE_DIR_FILE="${TMPDIR:-/tmp}/codocs_stale_dir_paths"

trap 'rm -f "$DEPS_FLAG" "$DEPS_FILE" "$STALE_DIR_FLAG" "$STALE_DIR_FILE"' EXIT

# All flags absent → nothing to check
if [ ! -f "$PENDING_FLAG" ] && [ ! -f "$PARENT_SYNC_FLAG" ] && [ ! -f "$DEPS_FLAG" ] && [ ! -f "$STALE_DIR_FLAG" ]; then
  exit 0
fi

commit_msg=$(cat "$COMMIT_MSG_FILE")

# ── Parse ## codocs-skip section ─────────────────────────────────────────
in_skip_section=false
global_skip=false
declare -a skip_paths=()

while IFS= read -r line; do
  if echo "$line" | grep -qE "^## codocs-skip"; then
    in_skip_section=true
    continue
  fi
  if [ "$in_skip_section" = true ]; then
    # Stop at next heading
    if echo "$line" | grep -qE "^##"; then
      break
    fi
    # Match list item: "- <content>"
    if echo "$line" | grep -qE "^- .+"; then
      item=$(echo "$line" | sed 's/^- //')
      if echo "$item" | grep -qE "^\[all\]"; then
        # Explicit global skip
        global_skip=true
      elif echo "$item" | grep -qE "^\.codocs/docs/"; then
        # path-specific .codocs/docs/ skip (Phase 3/4)
        path=$(echo "$item" | sed 's/:.*//')
        skip_paths+=("$path")
      fi
      # Other entries are silently ignored
    fi
  fi
done <<< "$commit_msg"

# Global skip → clear all flags and pass
if [ "$global_skip" = true ]; then
  rm -f "$PENDING_FLAG" "$PENDING_FILES" "$PARENT_SYNC_FLAG" "$MISSING_PARENTS"
  # STALE_DIR_FLAG and STALE_DIR_FILE cleaned by trap on exit 0
  exit 0
fi

block=false

# ── Check 1: codocs_needs_doc_check (Phase 2) ────────────────────────────
if [ -f "$PENDING_FLAG" ]; then
  if [ -f "$PENDING_FILES" ]; then
    # Check if all pending files are covered by path-specific skips
    # pending_files contains source paths (e.g. src/Runtime/Codec.cpp)
    # skip_paths contains .codocs/ paths (e.g. .codocs/src/Runtime/Codec.cpp.md)
    uncovered_phase2=()
    while IFS= read -r pending_file; do
      pending_file="${pending_file%$'\r'}"  # strip trailing \r (Windows CRLF)
      covered=false
      codocs_path=".codocs/docs/$pending_file.md"
      for sp in "${skip_paths[@]}"; do
        if [ "$sp" = "$codocs_path" ]; then
          covered=true
          break
        fi
      done
      [ "$covered" = false ] && uncovered_phase2+=("$pending_file")
    done < "$PENDING_FILES"

    if [ ${#uncovered_phase2[@]} -gt 0 ]; then
      block=true
      local_count=${#uncovered_phase2[@]}
      echo ""
      echo "[codocs] ❌ 以下受管控文件缺少文档更新或有效的跳过声明"
      echo ""
      echo "  未覆盖："
      for p in "${uncovered_phase2[@]}"; do
        echo "    $p  →  .codocs/docs/$p.md"
      done
      echo ""
      echo "  请 Read 对应 md 确认是否需要更新，然后："
      echo "  ❓ 不熟悉 codocs 规范？先读 .codocs/README.md"
      echo "  - 需要更新 → 修改 md 后 git add，重新提交"
      echo "  - 确认不需要 → 在 commit message 加 codocs-skip（须写具体理由）："
      echo "    ## codocs-skip"
      for p in "${uncovered_phase2[@]}"; do
        echo "    - .codocs/docs/$p.md: <具体理由>"
      done
      if [ "$local_count" -gt 3 ]; then
        echo "    # 文件较多时也可用: - [all]: <理由>"
      fi
      echo ""
    else
      rm -f "$PENDING_FLAG" "$PENDING_FILES"
    fi
  else
    block=true
    echo ""
    echo "[codocs] ❌ 以下受管控文件缺少文档更新或有效的跳过声明"
    echo ""
    echo "  请 Read 对应 md 确认是否需要更新，然后："
    echo "  - 需要更新 → 修改 md 后 git add，重新提交"
    echo "  - 确认不需要 → 在 commit message 加 codocs-skip（须写具体理由）："
    echo "    ## codocs-skip"
    echo "    - .codocs/docs/<文件路径>.md: <具体理由>"
    echo ""
  fi
fi

# ── Check 2: codocs_needs_parent_sync (Phase 3) ───────────────────────────
if [ -f "$PARENT_SYNC_FLAG" ]; then
  if [ -f "$MISSING_PARENTS" ]; then
    uncovered=()
    while IFS= read -r parent_path; do
      parent_path="${parent_path%$'\r'}"  # strip trailing \r (Windows CRLF)
      covered=false
      for sp in "${skip_paths[@]}"; do
        if [ "$sp" = "$parent_path" ]; then
          covered=true
          break
        fi
      done
      [ "$covered" = false ] && uncovered+=("$parent_path")
    done < "$MISSING_PARENTS"

    if [ ${#uncovered[@]} -gt 0 ]; then
      block=true
      parent_count=${#uncovered[@]}
      echo ""
      echo "[codocs] ❌ 以下父目录 MD 未随子文档同步更新"
      echo ""
      echo "  未覆盖："
      for p in "${uncovered[@]}"; do
        echo "    $p"
      done
      echo ""
      echo "  请 Read 上列 md 确认文档内容（架构说明、设计决策、索引表等）是否需要更新，然后："
      echo "  ❓ 不熟悉 codocs 规范？先读 .codocs/README.md"
      echo "  - 需要更新 → 修改 md 后 git add，重新提交"
      echo "  - 确认不需要 → 在 commit message 加 codocs-skip（须写具体理由）："
      echo "    ## codocs-skip"
      for p in "${uncovered[@]}"; do
        echo "    - $p: <具体理由>"
      done
      if [ "$parent_count" -gt 3 ]; then
        echo "    # 文件较多时也可用: - [all]: <理由>"
      fi
      echo ""
    else
      rm -f "$PARENT_SYNC_FLAG" "$MISSING_PARENTS"
    fi
  else
    rm -f "$PARENT_SYNC_FLAG"
  fi
fi

# ── Check 3: codocs_needs_dep_check (Phase 4) ────────────────────────────
if [ -f "$DEPS_FLAG" ] && [ -f "$DEPS_FILE" ]; then
  uncovered_deps=()
  while IFS= read -r dep_path; do
    dep_path="${dep_path%$'\r'}"  # strip trailing \r (Windows CRLF)
    covered=false
    for sp in "${skip_paths[@]}"; do
      if [ "$sp" = "$dep_path" ]; then covered=true; break; fi
    done
    [ "$covered" = false ] && uncovered_deps+=("$dep_path")
  done < "$DEPS_FILE"

  if [ ${#uncovered_deps[@]} -gt 0 ]; then
    block=true
    dep_count=${#uncovered_deps[@]}
    echo ""
    echo "[codocs] ❌ 以下依赖文档未随被依赖文件同步更新"
    echo ""
    echo "  未覆盖："
    for p in "${uncovered_deps[@]}"; do echo "    $p"; done
    echo ""
    echo "  请 Read 上列 md 确认是否需要更新，然后："
    echo "  ❓ 不熟悉 codocs 规范？先读 .codocs/README.md"
    echo "  - 需要更新 → 修改 md 后 git add，重新提交"
    echo "  - 确认不需要 → 在 commit message 加 codocs-skip（须写具体理由）："
    echo "    ## codocs-skip"
    for p in "${uncovered_deps[@]}"; do echo "    - $p: <具体理由>"; done
    if [ "$dep_count" -gt 3 ]; then
      echo "    # 文件较多时也可用: - [all]: <理由>"
    fi
    echo ""
  fi
fi

# ── Check 4: codocs_needs_stale_dir_check (STALE_DIR soft warning) ──────────
if [ -f "$STALE_DIR_FLAG" ] && [ -f "$STALE_DIR_FILE" ]; then
  uncovered_stale_dirs=()
  while IFS= read -r stale_line; do
    stale_line="${stale_line%$'\r'}"
    # Extract MD path from line like: [STALE_DIR]  .codocs/docs/src.md  (reason)
    md_path=$(echo "$stale_line" | sed 's/^\[STALE_DIR\][[:space:]]*//' | awk '{print $1}')
    covered=false
    for sp in "${skip_paths[@]}"; do
      if [ "$sp" = "$md_path" ]; then covered=true; break; fi
    done
    [ "$covered" = false ] && uncovered_stale_dirs+=("$stale_line")
  done < "$STALE_DIR_FILE"

  if [ ${#uncovered_stale_dirs[@]} -gt 0 ]; then
    block=true
    stale_dir_count=${#uncovered_stale_dirs[@]}
    echo ""
    echo "[codocs] ❌ 目录文档已过期（STALE_DIR），需审查后跳过或刷新"
    echo ""
    echo "  未覆盖："
    for line in "${uncovered_stale_dirs[@]}"; do echo "    $line"; done
    echo ""
    echo "  ⚠️  目录文档不只是索引——还应包含架构说明、设计决策、模块关系等内容。"
    echo "  请 Read 上列 md，确认文档内容（不只是索引表）是否仍准确。"
    echo ""
    echo "  选项 A（推荐）：审查并刷新哈希"
    echo "    python .codocs/scripts/codocs.py . review-stale <md-path>"
    echo "    python .codocs/scripts/codocs.py . refresh-hash <md-path>"
    echo ""
    echo "  选项 B（审查后跳过）："
    echo "    在 commit message 末尾写："
    echo "    ## codocs-skip"
    for line in "${uncovered_stale_dirs[@]}"; do
      md=$(echo "$line" | sed 's/^\[STALE_DIR\][[:space:]]*//' | awk '{print $1}')
      echo "    - $md: <具体理由（须说明文档内容不受影响）>"
    done
    if [ "$stale_dir_count" -gt 3 ]; then
      echo "    # 文件较多时也可用: - [all]: <理由>"
    fi
    echo ""
  fi
fi

if [ "$block" = true ]; then
  rm -f "$PENDING_FLAG" "$PENDING_FILES" "$PARENT_SYNC_FLAG" "$MISSING_PARENTS"
  exit 1
fi
exit 0
